package app.controller;

import app.service.AuthService;
import app.util.SceneSwitcher;
import javafx.fxml.FXML;
import javafx.scene.control.*;

public class AuthController {

    @FXML private TextField signInEmailField;
    @FXML private PasswordField signInPasswordField;
    @FXML private Label signInEmailErrorLabel;
    @FXML private Label signInPasswordErrorLabel;

    @FXML
    public void initialize() {
        hideError(signInEmailErrorLabel);
        hideError(signInPasswordErrorLabel);
    }

    @FXML
    private void onSubmitSignIn() {
        String email = signInEmailField.getText();
        String password = signInPasswordField.getText();

        hideError(signInEmailErrorLabel);
        hideError(signInPasswordErrorLabel);

        String emailError = AuthService.validateEmail(email);
        String passError = AuthService.validatePassword(password);

        if (emailError != null) {
            showError(signInEmailErrorLabel, emailError);
            return;
        }

        if (passError != null) {
            showError(signInPasswordErrorLabel, passError);
            return;
        }

        if (AuthService.login(email, password)) {
            // 👉 chuyển sang HOME
            SceneSwitcher.switchTo("view/home.fxml");
        } else {
            showError(signInPasswordErrorLabel, "Sai tài khoản hoặc mật khẩu");
        }
    }

    private void showError(Label label, String msg) {
        label.setText(msg);
        label.setVisible(true);
        label.setManaged(true);
    }

    private void hideError(Label label) {
        label.setVisible(false);
        label.setManaged(false);
    }
}