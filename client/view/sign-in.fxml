<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml" fx:controller="client.app.controller.AuthController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0" />
            </padding>
            <Button styleClass="secondary-button" text="Back to Home" onAction="#onBackHome" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="brand-title" text="Sign In" />
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="12.0" styleClass="auth-wrapper">
            <VBox spacing="12.0" styleClass="auth-card" maxWidth="420.0">
                <padding>
                    <Insets top="28.0" right="28.0" bottom="28.0" left="28.0" />
                </padding>
                <Label styleClass="section-title" text="Welcome Back" />
                <TextField fx:id="signInEmailField" promptText="Email" />
                <Label fx:id="signInEmailErrorLabel" styleClass="error-label" text=""
                    visible="false" managed="false" />
                <PasswordField fx:id="signInPasswordField" promptText="Password" />
                <Label fx:id="signInPasswordErrorLabel" styleClass="error-label" text=""
                    visible="false" managed="false" />
                <Button fx:id="signInSubmitButton" styleClass="primary-button" text="Sign In"
                    maxWidth="1.7976931348623157E308" onAction="#onSubmitSignIn" />
                <HBox alignment="CENTER" spacing="6.0">
                    <Label styleClass="card-meta" text="No account yet?" />
                    <Button styleClass="nav-ghost" text="Sign Up" onAction="#onOpenSignUp" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>