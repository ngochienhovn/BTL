<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/resources/css/home-page.css" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml" fx:controller="client.app.controller.SellerItemsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0" />
            </padding>
            <Button styleClass="secondary-button" text="← Back to Home" onAction="#onBackHome" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="brand-title" text="Seller Items" />
        </HBox>
    </top>
    <center>
        <HBox spacing="16.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>
            <VBox spacing="10.0" styleClass="auction-card" prefWidth="360.0">
                <padding>
                    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                </padding>
                <Label styleClass="section-title" text="My Items" />
                <ListView fx:id="itemListView" prefHeight="520.0" />
            </VBox>
            <VBox spacing="10.0" styleClass="auction-card" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                </padding>
                <Label styleClass="section-title" text="Item Form" />
                <ComboBox fx:id="typeCombo" />
                <TextField fx:id="nameField" promptText="Name" />
                <TextArea fx:id="descriptionArea" promptText="Description" prefRowCount="4" />
                <TextField fx:id="startingBidField" promptText="Starting bid" />
                <TextField fx:id="imageUrlField" promptText="Image URL" />
                <HBox spacing="8.0">
                    <Button styleClass="primary-button" text="Add" onAction="#onAddItem" />
                    <Button styleClass="secondary-button" text="Update" onAction="#onUpdateItem" />
                    <Button styleClass="danger-button" text="Delete" onAction="#onDeleteItem" />
                    <Button styleClass="primary-button" text="Create Session"
                        onAction="#onCreateSession" />
                </HBox>
                <Label fx:id="messageLabel" styleClass="result-label" text="" />
            </VBox>
        </HBox>
    </center>
</BorderPane>